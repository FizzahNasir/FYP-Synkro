# =============================================================================
# Synkro Backend — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# All integration sections are OPTIONAL unless marked REQUIRED.
# =============================================================================


# -----------------------------------------------------------------------------
# [REQUIRED] Application
# -----------------------------------------------------------------------------
APP_NAME=Synkro
APP_VERSION=1.0.0
ENVIRONMENT=development

# Generate a strong secret key (minimum 32 characters).
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production-min-32-characters

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# [REQUIRED] Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (async driver).
# Option A — Local PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/synkro
# Option B — Neon (free cloud PostgreSQL, recommended for evaluation):
#   Sign up at https://neon.tech → create a project → copy the connection string
#   and replace "postgresql://" with "postgresql+asyncpg://" and add "?ssl=require"
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require


# -----------------------------------------------------------------------------
# [REQUIRED] Redis
# -----------------------------------------------------------------------------
# Required for background task processing (Celery).
# Option A — Local Redis:
#   REDIS_URL=redis://localhost:6379/0
# Option B — Redis Cloud (free tier): https://redis.com/try-free/
# Option C — Skip Redis: remove Celery workers and rely on FastAPI background tasks.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# [REQUIRED — pick ONE] AI / Transcription
# -----------------------------------------------------------------------------
# Groq (recommended — free tier, fast):
# Get API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# OpenAI (alternative — paid):
# Get API key at: https://platform.openai.com/api-keys
# Leave blank if using Groq.
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# [OPTIONAL] Speaker Diarization (who spoke when)
# -----------------------------------------------------------------------------
# Tier 1 — HuggingFace (free, requires model license acceptance):
#   1. Create account at https://huggingface.co
#   2. Accept license: https://huggingface.co/pyannote/speaker-diarization-3.1
#   3. Generate token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Tier 2 — AssemblyAI (free tier: 5 hours/month):
#   Get key at: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=


# -----------------------------------------------------------------------------
# [OPTIONAL] File Storage
# -----------------------------------------------------------------------------
# By default, audio files are stored locally in backend/uploads/.
# Configure AWS S3 or Cloudinary for persistent cloud storage.

# AWS S3:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Cloudinary (alternative to S3):
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret


# -----------------------------------------------------------------------------
# [OPTIONAL] Gmail Integration
# -----------------------------------------------------------------------------
# Enables syncing emails into the Emails dashboard tab.
# Requires a Gmail account with 2-Step Verification enabled.
# Steps:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" + your device → Generate
#   3. Copy the 16-character App Password (spaces are fine)
GMAIL_EMAIL=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx


# -----------------------------------------------------------------------------
# [OPTIONAL] Google OAuth (Calendar + Google Meet)
# -----------------------------------------------------------------------------
# Enables Google Calendar sync and auto-creating Google Meet links from tasks.
# Steps:
#   1. Go to https://console.cloud.google.com → Create a project
#   2. APIs & Services → Enable Library → enable:
#        - Google Calendar API
#        - Google People API (optional)
#   3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#        - Application type: Web application
#        - Authorised redirect URIs: http://localhost:8000/api/integrations/google-calendar/callback
#   4. Download credentials and copy Client ID + Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/integrations/google-calendar/callback


# -----------------------------------------------------------------------------
# [OPTIONAL] Slack Integration
# -----------------------------------------------------------------------------
# Enables syncing Slack messages and direct messages into Synkro.
# Steps:
#   1. Go to https://api.slack.com/apps → Create New App → From scratch
#   2. Give it a name (e.g., "Synkro") and select your workspace
#   3. OAuth & Permissions → Redirect URLs → Add:
#        http://localhost:8000/api/integrations/slack/callback
#   4. OAuth & Permissions → Bot Token Scopes → Add:
#        channels:history, channels:read, users:read, users:read.email,
#        im:history, im:read, chat:write
#   5. Event Subscriptions → Enable Events → Request URL:
#        http://<your-ngrok-url>/api/slack/events
#        Subscribe to bot events: message.channels, message.im
#   6. Basic Information → Client ID, Client Secret, Signing Secret
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/integrations/slack/callback
SLACK_SIGNING_SECRET=


# -----------------------------------------------------------------------------
# [OPTIONAL] Jira Integration
# -----------------------------------------------------------------------------
# Enables two-way Jira sync (tasks ↔ Jira issues + comment sync).
# Jira credentials are entered per-user in the UI (Settings → Integrations → Jira).
# No server-side OAuth app needed — each user provides:
#   - Jira domain (e.g., your-company.atlassian.net)
#   - Atlassian account email
#   - Personal API token from https://id.atlassian.com → Security → API tokens
#
# For real-time webhook sync from Jira → Synkro you need a public URL.
# Use ngrok for local development:
#   ngrok http 8000
#   Then update BACKEND_URL with your ngrok https URL.
JIRA_WEBHOOK_SECRET=your-random-webhook-secret
BACKEND_URL=https://your-ngrok-subdomain.ngrok-free.app


# -----------------------------------------------------------------------------
# [OPTIONAL] Zoom Integration
# -----------------------------------------------------------------------------
# Enables Zoom meeting link generation.
# Steps:
#   1. Go to https://marketplace.zoom.us/develop/create → OAuth app
#   2. Add Redirect URL: http://localhost:8000/api/integrations/zoom/callback
#   3. Scopes: meeting:write:admin, meeting:read:admin
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:8000/api/integrations/zoom/callback
ZOOM_WEBHOOK_SECRET_TOKEN=


# -----------------------------------------------------------------------------
# [OPTIONAL] Demo / Testing
# -----------------------------------------------------------------------------
# Auto-provision Slack for every newly registered user (useful for demos).
DEMO_SLACK_TOKEN=
DEMO_SLACK_TEAM_ID=


# -----------------------------------------------------------------------------
# CORS / URLs
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
FRONTEND_URL=http://localhost:3000
